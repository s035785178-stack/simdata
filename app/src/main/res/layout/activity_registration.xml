<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layoutDirection="rtl"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="רישום כלקוח חדש"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvRegistrationLineNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="מספר קו במכשיר: לא זוהה"
            android:textColor="#FFFFFF"
            android:gravity="end"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etRegistrationName"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="שם מלא"
            android:background="#FFFFFF"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/etRegistrationPhone"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="טלפון"
            android:background="#FFFFFF"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/etCarModel"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="דגם רכב"
            android:background="#FFFFFF"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/etCarNumber"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="מספר רכב"
            android:background="#FFFFFF"
            android:layout_marginBottom="10dp" />

        <Spinner
            android:id="@+id/spinnerPackage"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp"
            android:background="#FFFFFF" />

        <Button
            android:id="@+id/btnRegisterCustomer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="הרשמה"
            android:textColor="#FFFFFF"
            android:backgroundTint="#842F1B" />

    </LinearLayout>
</ScrollView>
