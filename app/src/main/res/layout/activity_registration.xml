<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:orientation="vertical"
    android:background="@drawable/bg_screen"
    android:padding="18dp">

    <ImageView
        android:id="@+id/logoRegistration"
        android:layout_width="280dp"
        android:layout_height="100dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/stereo_logo"
        android:scaleType="fitCenter"
        android:contentDescription="logo" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="רישום כלקוח חדש"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginBottom="18dp" />

            <EditText
                android:id="@+id/etRegistrationName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input"
                android:hint="שם מלא"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:gravity="end|center_vertical"
                android:textAlignment="viewEnd"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etRegistrationPhone"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input"
                android:hint="טלפון"
                android:inputType="phone"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:gravity="end|center_vertical"
                android:textAlignment="viewEnd"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:layout_marginBottom="18dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="86dp"
                android:orientation="horizontal"
                android:layoutDirection="rtl"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnRegisterCustomer"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="7dp"
                    android:background="@drawable/bg_button_brand"
                    android:text="הרשמה"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnRegistrationHelp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="7dp"
                    android:background="@drawable/bg_button_gray"
                    android:text="עזרה בהרשמה"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
