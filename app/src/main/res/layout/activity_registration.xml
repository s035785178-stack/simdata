<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layoutDirection="rtl"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="רישום כלקוח חדש"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvRegistrationLineNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="מספר קו במכשיר: לא זוהה"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="end"
            android:textAlignment="viewEnd"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etRegistrationName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="10dp"
            android:background="#FFFFFF"
            android:hint="שם מלא"
            android:textColor="#111111"
            android:textColorHint="#666666"
            android:gravity="end|center_vertical"
            android:textAlignment="viewEnd"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true" />

        <EditText
            android:id="@+id/etRegistrationPhone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="10dp"
            android:background="#FFFFFF"
            android:hint="טלפון"
            android:inputType="phone"
            android:textColor="#111111"
            android:textColorHint="#666666"
            android:gravity="end|center_vertical"
            android:textAlignment="viewEnd"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true" />

        <EditText
            android:id="@+id/etCarModel"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="10dp"
            android:background="#FFFFFF"
            android:hint="דגם רכב"
            android:textColor="#111111"
            android:textColorHint="#666666"
            android:gravity="end|center_vertical"
            android:textAlignment="viewEnd"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true" />

        <EditText
            android:id="@+id/etCarNumber"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="10dp"
            android:background="#FFFFFF"
            android:hint="מספר רכב"
            android:textColor="#111111"
            android:textColorHint="#666666"
            android:gravity="end|center_vertical"
            android:textAlignment="viewEnd"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true" />

        <Spinner
            android:id="@+id/spinnerPackage"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="18dp"
            android:background="#FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layoutDirection="rtl"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnRegisterCustomer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:backgroundTint="#842F1B"
                android:text="הרשמה"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnHelp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#2A2A2A"
                android:text="עזרה"
                android:textColor="#FFFFFF" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
