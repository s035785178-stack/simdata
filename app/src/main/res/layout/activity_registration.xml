<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#111111">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:layoutDirection="rtl">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="רישום כלקוח חדש"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvRegistrationLineNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="מספר קו במכשיר: לא זוהה"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/etRegistrationName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="שם מלא"
            android:textColor="#111111"
            android:textColorHint="#777777"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:textDirection="rtl" />

        <EditText
            android:id="@+id/etRegistrationPhone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="טלפון"
            android:inputType="phone"
            android:textColor="#111111"
            android:textColorHint="#777777"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:textDirection="rtl" />

        <EditText
            android:id="@+id/etCarModel"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="דגם רכב"
            android:textColor="#111111"
            android:textColorHint="#777777"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:textDirection="rtl" />

        <EditText
            android:id="@+id/etCarNumber"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="מספר רכב"
            android:textColor="#111111"
            android:textColorHint="#777777"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:textDirection="rtl" />

        <Spinner
            android:id="@+id/spinnerPackage"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnRegisterCustomer"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="הרשמה"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnHelp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="עזרה"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
