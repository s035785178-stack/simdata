<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layoutDirection="rtl"
        android:orientation="vertical"
        android:padding="14dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/logoRegistration"
            android:layout_width="250dp"
            android:layout_height="90dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="10dp"
            android:contentDescription="logo"
            android:scaleType="fitCenter"
            android:src="@drawable/stereo_logo" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:padding="12dp"
            android:text="רישום כלקוח חדש"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tvRegistrationLineNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:padding="12dp"
            android:text="מספר קו במכשיר: לא זוהה"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="end"
            android:textAlignment="viewEnd"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp"
            android:layoutDirection="rtl">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="שם מלא"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etRegistrationName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_light"
                android:backgroundTint="@null"
                android:hint="שם מלא"
                android:textColor="#1B1B1B"
                android:textColorHint="#6F6F6F"
                android:gravity="end|center_vertical"
                android:textAlignment="viewEnd"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="טלפון"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etRegistrationPhone"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_light"
                android:backgroundTint="@null"
                android:hint="טלפון"
                android:inputType="phone"
                android:textColor="#1B1B1B"
                android:textColorHint="#6F6F6F"
                android:gravity="end|center_vertical"
                android:textAlignment="viewEnd"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="דגם רכב"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etCarModel"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_light"
                android:backgroundTint="@null"
                android:hint="דגם רכב"
                android:textColor="#1B1B1B"
                android:textColorHint="#6F6F6F"
                android:gravity="end|center_vertical"
                android:textAlignment="viewEnd"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="מספר רכב"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etCarNumber"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_light"
                android:backgroundTint="@null"
                android:hint="מספר רכב"
                android:textColor="#1B1B1B"
                android:textColorHint="#6F6F6F"
                android:gravity="end|center_vertical"
                android:textAlignment="viewEnd"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="חבילת גלישה"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerPackage"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_light"
                android:backgroundTint="@null"
                android:paddingHorizontal="10dp"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:layoutDirection="rtl">

            <Button
                android:id="@+id/btnRegisterCustomer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:background="@drawable/bg_button_brand"
                android:text="הרשמה"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnHelp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:background="@drawable/bg_button_gray"
                android:text="עזרה"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
