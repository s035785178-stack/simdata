<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:layoutDirection="rtl">

        <TextView
            android:id="@+id/tvCustomerSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:text="טוען נתונים..."
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMissingCustomer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_button_orange"
            android:padding="12dp"
            android:text="הלקוח לא קיים במערכת"
            android:textAlignment="center"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card"
            android:padding="12dp"
            android:text="✏ עריכת פרטי לקוח"
            android:textAlignment="center"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp"
            android:layoutDirection="rtl">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="שם לקוח"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_light"
                android:backgroundTint="@null"
                android:gravity="end|center_vertical"
                android:hint="הכנס שם לקוח"
                android:inputType="textPersonName"
                android:paddingHorizontal="14dp"
                android:textAlignment="viewEnd"
                android:textColor="#1B1B1B"
                android:textColorHint="#6F6F6F" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="טלפון"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_light"
                android:backgroundTint="@null"
                android:gravity="end|center_vertical"
                android:hint="הכנס מספר טלפון"
                android:inputType="phone"
                android:paddingHorizontal="14dp"
                android:textAlignment="viewEnd"
                android:textColor="#1B1B1B"
                android:textColorHint="#6F6F6F" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="דגם רכב"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etCarModel"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_light"
                android:backgroundTint="@null"
                android:gravity="end|center_vertical"
                android:hint="הכנס דגם רכב"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:textAlignment="viewEnd"
                android:textColor="#1B1B1B"
                android:textColorHint="#6F6F6F" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="מספר רכב"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etCarNumber"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_light"
                android:backgroundTint="@null"
                android:digits="0123456789"
                android:gravity="end|center_vertical"
                android:hint="הכנס מספר רכב"
                android:inputType="number"
                android:paddingHorizontal="14dp"
                android:textAlignment="viewEnd"
                android:textColor="#1B1B1B"
                android:textColorHint="#6F6F6F" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="חבילת גלישה"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerPackage"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_light"
                android:backgroundTint="@null"
                android:paddingHorizontal="10dp"
                android:spinnerMode="dropdown" />

            <Button
                android:id="@+id/btnValidityMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_gray"
                android:gravity="center"
                android:minHeight="56dp"
                android:padding="12dp"
                android:text="📅 תוקף חבילה (אוטומטי) - לא ידוע"
                android:textAllCaps="false"
                android:textAlignment="center"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:layoutDirection="rtl">

            <Button
                android:id="@+id/btnSaveCustomer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:background="@drawable/bg_button_brand"
                android:text="💾 שמור"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnBackCustomer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:background="@drawable/bg_button_gray"
                android:text="⬅ חזרה"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
