<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:padding="18dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:padding="14dp"
        android:text="💳 חידוש חבילת גלישה"
        android:textAlignment="center"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginTop="14dp">

        <LinearLayout
            android:id="@+id/cardTrial"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧪 חבילת ניסיון" android:textColor="@color/text_primary" android:textSize="24sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="4GB" android:textColor="@color/text_primary" android:textSize="30sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="חודשיים" android:textColor="@color/text_secondary" android:textSize="22sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="40₪" android:textColor="@color/text_primary" android:textSize="30sp" android:textStyle="bold"/>
            <Button android:id="@+id/btnTrial" android:layout_width="match_parent" android:layout_height="70dp" android:layout_marginTop="14dp" android:background="@drawable/bg_button_orange" android:text="בחר חבילה" android:textAllCaps="false" android:textColor="@color/text_primary" android:textSize="20sp" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardLong"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:background="@drawable/bg_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💼 חבילה חסכונית" android:textColor="@color/text_primary" android:textSize="24sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="36GB" android:textColor="@color/text_primary" android:textSize="30sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="60 חודשים" android:textColor="@color/text_secondary" android:textSize="22sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="400₪" android:textColor="@color/text_primary" android:textSize="30sp" android:textStyle="bold"/>
            <Button android:id="@+id/btnLong" android:layout_width="match_parent" android:layout_height="70dp" android:layout_marginTop="14dp" android:background="@drawable/bg_button_orange" android:text="בחר חבילה" android:textAllCaps="false" android:textColor="@color/text_primary" android:textSize="20sp" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardFeatured"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐ החבילה המומלצת" android:textColor="@color/text_primary" android:textSize="24sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="100GB" android:textColor="@color/text_primary" android:textSize="30sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="שנתיים" android:textColor="@color/text_secondary" android:textSize="22sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="250₪" android:textColor="@color/text_primary" android:textSize="30sp" android:textStyle="bold"/>
            <Button android:id="@+id/btnFeatured" android:layout_width="match_parent" android:layout_height="70dp" android:layout_marginTop="14dp" android:background="@drawable/bg_button_brand" android:text="בחר חבילה" android:textAllCaps="false" android:textColor="@color/text_primary" android:textSize="20sp" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="החבילה תקפה עד ניצול הנפח או עד תום התקופה – המוקדם מביניהם"
        android:textAlignment="center"
        android:textColor="@color/text_secondary"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnBackPackages"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_gray"
        android:text="⬅ חזרה"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

</LinearLayout>
