<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_screen"
    android:padding="10dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚙ מצב טכנאי"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:gravity="center"/>

    <TextView
        android:id="@+id/tvTechInfo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_card"
        android:layout_marginTop="10dp"
        android:padding="10dp"
        android:textColor="@color/text_primary"/>

    <!-- כפתורים -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnEditCustomer"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="👤 עריכת לקוח"
            android:background="@drawable/bg_button_green"
            android:textColor="@color/text_primary"/>

        <Button
            android:id="@+id/btnTechNetwork"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="📡 בדיקת רשת"
            android:background="@drawable/bg_button_blue"
            android:textColor="@color/text_primary"
            android:layout_marginTop="6dp"/>

        <Button
            android:id="@+id/btnTechSupportQr"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="📤 שליחת נתונים"
            android:background="@drawable/bg_button_orange"
            android:textColor="@color/text_primary"
            android:layout_marginTop="6dp"/>

        <Button
            android:id="@+id/btnClearHistory"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🧹 נקה היסטוריה"
            android:background="@drawable/bg_button_gray"
            android:textColor="@color/text_primary"
            android:layout_marginTop="6dp"/>

        <Button
            android:id="@+id/btnClearAll"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="♻ אפס נתונים"
            android:background="@drawable/bg_button_brand"
            android:textColor="@color/text_primary"
            android:layout_marginTop="6dp"/>

        <Button
            android:id="@+id/btnBackTech"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="⬅ חזרה"
            android:background="@drawable/bg_button_gray"
            android:textColor="@color/text_primary"
            android:layout_marginTop="6dp"/>

    </LinearLayout>

</LinearLayout>
