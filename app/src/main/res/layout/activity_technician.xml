<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_screen"
    android:padding="10dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="מצב טכנאי"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:gravity="center"/>

    <TextView
        android:id="@+id/tvTechInfo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_card"
        android:layout_marginTop="10dp"
        android:padding="10dp"
        android:textColor="@color/text_primary"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:useDefaultMargins="true">

        <Button android:id="@+id/btnEditCustomer" android:text="עריכת לקוח"/>
        <Button android:id="@+id/btnTechNetwork" android:text="בדיקת רשת"/>
        <Button android:id="@+id/btnTechSupportQr" android:text="שליחה"/>

        <Button android:id="@+id/btnClearHistory" android:text="היסטוריה"/>
        <Button android:id="@+id/btnClearAll" android:text="איפוס"/>
        <Button android:id="@+id/btnBackTech" android:text="חזרה"/>

    </GridLayout>

</LinearLayout>
