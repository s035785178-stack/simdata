<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:padding="10dp">

    <TextView
        android:id="@+id/tvTechInfo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:textSize="15sp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2">

        <Button android:id="@+id/btnEditCustomer" android:text="✏ פרטי לקוח"/>
        <Button android:id="@+id/btnTechNetwork" android:text="📡 רשת"/>
        <Button android:id="@+id/btnTechSupportQr" android:text="📤 שלח"/>
        <Button android:id="@+id/btnClearHistory" android:text="🧹 היסטוריה"/>
        <Button android:id="@+id/btnClearAll" android:text="♻ איפוס"/>
        <Button android:id="@+id/btnBackTech" android:text="⬅ חזרה"/>

    </GridLayout>
</LinearLayout>
