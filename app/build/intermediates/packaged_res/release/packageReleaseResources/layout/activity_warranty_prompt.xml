<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="24dp"
        android:paddingEnd="28dp"
        android:paddingBottom="24dp">

        <ImageView
            android:id="@+id/logoWarranty"
            android:layout_width="220dp"
            android:layout_height="82dp"
            android:adjustViewBounds="true"
            android:contentDescription="Stereo Tip"
            android:scaleType="centerInside"
            android:src="@drawable/stereo_logo" />

        <TextView
            android:id="@+id/tvShieldWarranty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="🛡️"
            android:textSize="46sp" />

        <TextView
            android:id="@+id/tvWarrantyTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="הפעלת אחריות למכשיר"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvWarrantySubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="כדי לקבל שירות מלא, עדכונים ותמיכה מהירה, מומלץ להפעיל אחריות למכשיר שלך כבר עכשיו."
            android:textColor="#DADADA"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvWarrantyTrustText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="האחריות מאפשרת זיהוי מהיר במערכת וקבלת שירות ללא עיכובים"
            android:textColor="#AFAFAF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <Button
                android:id="@+id/btnActivateWarrantyPrompt"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:backgroundTint="#2E7D32"
                android:text="הפעל אחריות עכשיו"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnSkipWarrantyPrompt"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="14dp"
                android:backgroundTint="#555555"
                android:text="דלג כרגע (לא מומלץ)"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnNoWarrantyExternalPrompt"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="14dp"
                android:backgroundTint="#C62828"
                android:text="בטל אחריות - המוצר לא נרכש בסטריאו טיפ"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/successContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvSuccessIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="48sp" />

                <TextView
                    android:id="@+id/tvSuccessTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="האחריות הופעלה בהצלחה"
                    android:textColor="#6EEB83"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSuccessCountdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="מעביר לבדיקה אוטומטית בעוד 3 שניות..."
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
